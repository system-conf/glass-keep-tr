{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "dist"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    {
      "src": "/((?:assets|favicon.*|pwa.*|apple-touch.*|robots.txt|vite.svg).*)",
      "dest": "/dist/$1"
    },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ],
  "env": {
    "VERCEL": "1"
  }
}
